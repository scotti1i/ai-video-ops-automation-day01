# 可选：真实脚本/分镜生成。零密钥 Demo 不需要。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
# 兼容中继可填写域名根或完整 API 前缀；域名根会自动补 /v1。
OPENAI_BASE_URL=

# 可选：选哪个引擎来写脚本。可填 mock（内置示例模板）、openai、
# claude-cli（本机 claude 命令）、codex-cli（本机 codex 命令），默认 openai。
# 选中的引擎不可用时（命令没装或密钥没配），启动时会提示并自动改用内置示例模板。
VIDEO_OPS_SCRIPT_PRODUCER=
# 可选：命令行引擎单次写脚本最多等多少秒，默认 240。
VIDEO_OPS_CLI_TIMEOUT=

# 可选：兼容 publish_single.py 的 YouTube uploader 目录和严格频道标识。
# 目录内必须包含 publish_single.py、auth.py 和自己的 .venv；不要复制 token。
YOUTUBE_UPLOAD_DIR=
YOUTUBE_EXPECTED_CHANNEL=
# 可选：单独保存只用于评论读取、含 youtube.force-ssl 的 token。
YOUTUBE_COMMENT_TOKEN_PATH=

# 本地服务设置。
VIDEO_OPS_API_PORT=8787
VIDEO_OPS_WEB_PORT=5173
